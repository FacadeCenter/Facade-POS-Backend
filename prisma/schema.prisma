generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x", "debian-openssl-1.1.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  PLATFORM_ADMIN
  TENANT_ADMIN
  TENANT_MANAGER
  TENANT_CASHIER
}

enum Plan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum PaymentType {
  CASH
  CARD
  SPLIT
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum ExpenseCategory {
  RENT
  UTILITIES
  SALARIES
  SUPPLIES
  MARKETING
  MAINTENANCE
  OTHER
}

enum DeviceStatus {
  ONLINE
  OFFLINE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIAL
}

enum InvoiceStatus {
  PAID
  OPEN
  OVERDUE
  VOID
}

enum PaymentMethod {
  CARD
  BANK_TRANSFER
  CASH
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Company {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  phone       String?
  address     String?
  logoUrl     String?
  plan        Plan      @default(FREE)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  branches    Branch[]
  staff       Staff[]
  products    Product[]
  categories  Category[]
  customers   Customer[]
  expenses    Expense[]
  suppliers   Supplier[]

  devices       Device[]
  subscriptions Subscription[]
  invoices      Invoice[]
  tickets       SupportTicket[]
  featureFlags  FeatureFlag[]

  @@map("companies")
}

model Branch {
  id          String   @id @default(cuid())
  name        String
  address     String?
  phone       String?
  isActive    Boolean  @default(true)
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orders      Order[]
  staff       Staff[]
  devices     Device[]
  inventory   Inventory[]

  @@index([companyId])
  @@map("branches")
}

model Staff {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(TENANT_CASHIER)
  isActive     Boolean  @default(true)
  companyId    String?
  branchId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company      Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch       Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  orders       Order[]

  @@index([companyId])
  @@index([branchId])
  @@map("staff")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  description String?
  companyId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products    Product[]

  @@index([companyId])
  @@unique([name, companyId])
  @@map("categories")
}

model Product {
  id          String      @id @default(cuid())
  name        String
  sku         String?
  description String?
  price       Float
  cost        Float       @default(0)
  imageUrl    String?
  isActive    Boolean     @default(true)
  companyId   String
  categoryId  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category    Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems  OrderItem[]
  inventory   Inventory[]

  @@index([companyId])
  @@index([categoryId])
  @@unique([sku, companyId])
  @@map("products")
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?
  address     String?
  points      Int      @default(0)
  totalSpent  Float    @default(0)
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@index([companyId])
  @@map("customers")
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String
  branchId    String
  customerId  String?
  staffId     String?
  status      OrderStatus @default(COMPLETED)
  subtotal    Float
  discount    Float       @default(0)
  tax         Float       @default(0)
  total       Float
  paymentType PaymentType
  note        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  branch      Branch      @relation(fields: [branchId], references: [id])
  customer    Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  staff       Staff?      @relation(fields: [staffId], references: [id], onDelete: SetNull)
  items       OrderItem[]

  @@index([branchId, createdAt])
  @@index([customerId])
  @@unique([orderNumber, branchId])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int
  unitPrice   Float
  discount    Float   @default(0)
  total       Float

  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Expense {
  id          String          @id @default(cuid())
  title       String
  amount      Float
  category    ExpenseCategory @default(OTHER)
  description String?
  date        DateTime        @default(now())
  companyId   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

model Supplier {
  id          String   @id @default(cuid())
  type        String   @default("INDIVIDUAL") // INDIVIDUAL or COMPANY
  name        String
  email       String?
  phone       String?
  address     String?
  companyName String?
  regNo       String?
  coverArea   String?
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("suppliers")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  module    String
  userId    String
  companyId String
  details   Json?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model Device {
  id          String       @id @default(cuid())
  name        String
  companyId   String
  branchId    String
  status      DeviceStatus @default(OFFLINE)
  appVersion  String?
  lastSyncAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch      Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([branchId])
  @@map("devices")
}

model Subscription {
  id          String             @id @default(cuid())
  companyId   String
  plan        Plan
  status      SubscriptionStatus @default(ACTIVE)
  renewalDate DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("subscriptions")
}

model Invoice {
  id          String        @id @default(cuid())
  companyId   String
  amount      Float
  status      InvoiceStatus @default(OPEN)
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payments    Payment[]

  @@index([companyId])
  @@map("invoices")
}

model Payment {
  id          String        @id @default(cuid())
  invoiceId   String
  amount      Float
  method      PaymentMethod @default(CARD)
  createdAt   DateTime      @default(now())

  invoice     Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model SupportTicket {
  id          String         @id @default(cuid())
  companyId   String
  userId      String?
  subject     String
  description String?
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  @@index([companyId, status])
  @@map("support_tickets")
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String
  enabled     Boolean  @default(false)
  companyId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([key, companyId])
  @@index([companyId])
  @@map("feature_flags")
}

model Inventory {
  id        String   @id @default(cuid())
  productId String
  branchId  String
  quantity  Int      @default(0)
  minStock  Int      @default(5)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([productId, branchId])
  @@index([branchId])
  @@index([productId])
  @@map("inventory")
}
